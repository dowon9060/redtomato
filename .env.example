# 로컬에서 scripts/local-api.mjs 가 읽습니다 (.env 권장, git에 올리지 마세요)
LOCAL_API_PORT=3001

# 공개 배포 도메인(참고): https://redtomato.kr
#
# 프론트(Vite 빌드): 창업 문의 API 베이스 — Worker 호스트만 쓸 때 필요
# (redtomato.kr 과 같은 호스트에서 /api 를 쓰면 비워 두세요)
# VITE_API_ORIGIN=https://retomato.<계정>.workers.dev

# 접수 로그 출력 (프로덕션 Vercel 함수 로그)
FRANCHISE_NOTIFY_LOG=1

# 창업 문의 알림 수신 (미설정 시 redtomatopizza1@gmail.com 사용)
FRANCHISE_NOTIFY_EMAIL=redtomatopizza1@gmail.com

# ── 방법 A: Gmail SMTP (Google 계정 앱 비밀번호 필요) ──
# https://support.google.com/accounts/answer/185833
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@gmail.com
# SMTP_PASS=앱비밀번호16자리
# FRANCHISE_MAIL_FROM_NAME=빨간토마토피자 창업문의

# ── 방법 B: Resend (https://resend.com) ──
# 발신 주소 도메인은 Resend 대시보드에서 인증해야 합니다.
# RESEND_API_KEY=re_xxxxxxxx
# FRANCHISE_MAIL_FROM=빨간토마토피자 <notify@예시도메인.com>

# 이후 문자/알림 연동 시 수신 번호 등 (예시)
# FRANCHISE_NOTIFY_PHONE=01000000000
